# Environment variables — copy to .env for local development (never commit .env; GR-001).
# Every variable the application reads MUST be listed here with a dummy value and a
# one-line comment (ARC-010). Deployed environments use the platform secret manager.

# --- template examples; replace with real variables when instantiating ---
# APP_ENV=development            # runtime environment: development | staging | production
# DATABASE_URL=postgres://user:CHANGE_ME@localhost:5432/app   # primary datastore
# LOG_LEVEL=info                 # trace | debug | info | warn | error
